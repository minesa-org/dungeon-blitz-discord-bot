{
	"rewrites": [
		{
			"source": "/",
			"destination": "/api/index"
		}
	],
	"functions": {
		"api/index.ts": {
			"maxDuration": 10,
			"includeFiles": "pages/verify.html"
		},
		"api/discord-linked-roles/connect.ts": {
			"maxDuration": 10,
			"includeFiles": "pages/verify.html"
		},
		"api/interactions.ts": {
			"maxDuration": 10,
			"includeFiles": "{src/commands/**,src/components/**,src/utils/**}"
		},
		"api/discord-oauth-callback.ts": {
			"maxDuration": 10,
			"includeFiles": "{dist/**,pages/**}"
		}
	},
	"buildCommand": "npm run build",
	"outputDirectory": ".",
	"installCommand": "npm install"
}
